include "my_robot.inc"

resolution 0.05
interval_sim 10  # 控制在100Hz，解决虚拟机卡顿，呼应你论文优化部分！

window (
  size [ 800 800 ]
  scale 20.490
)

floorplan (
  name "s1_map"
  bitmap "../maps/s1_mixed.pgm"
  size [20.000 20.000 0.500]
  pose [2.300 0.533 0.000 0.000]
)

my_robot (
  pose [2.000 2.000 0.000 0.000]  # 机器人的出生点
  color "red"
)