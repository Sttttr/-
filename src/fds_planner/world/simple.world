define robot position (
  size [0.35 0.35 0.25]
  gui_nose 1
  drive "diff"
)
define map model ( color "black" boundary 1 gui_noshow 0 gui_grid 1 laser_return 1 )
window ( size [600 600] center [0 0] rotate [0 0] scale 20 )
